# =============================================================================
# Kiwi Party — environment configuration
# Copy this file to `.env` and fill in the values you want to enable.
# Every integration is OPTIONAL: with keys set, the real API is used; without
# them, the app falls back to a working dev behaviour (mock payment, dev OTP,
# in-app-only notifications, deterministic AI). So the app works out of the box.
# =============================================================================

# --- Core (required) --------------------------------------------------------
# SQLite for local dev. For production, use a Postgres URL and change the
# datasource provider in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# JWT signing secret for auth tokens — use a long random value in production.
JWT_SECRET="dev-only-change-me-to-a-long-random-secret-string"

# Public site URL (used for sitemap.xml / robots.txt absolute URLs).
NEXT_PUBLIC_SITE_URL="http://localhost:3000"


# --- AI: Anthropic / Claude -------------------------------------------------
# When set, AI features (product descriptions, search query parsing, the
# sourcing assistant) use Claude. Without it they use a deterministic fallback.
# ANTHROPIC_API_KEY="sk-ant-..."
# KIWI_AI_MODEL="claude-opus-4-8"


# --- OTP / SMS: MSG91 -------------------------------------------------------
# When MSG91_AUTH_KEY is set, login OTPs are generated and sent by SMS.
# Without it, the fixed DEV_OTP below is accepted (so you can log in in dev).
DEV_OTP="123456"
# MSG91_AUTH_KEY=""
# MSG91_SENDER_ID="KIWIPT"
# MSG91_OTP_TEMPLATE_ID=""
# SMS_COUNTRY_CODE="91"


# --- Payments: Razorpay -----------------------------------------------------
# When key id + secret are set, /api/payments/razorpay/order creates real
# Razorpay orders and the webhook confirms payments. Without them, checkout
# records a mock payment so the flow still completes.
# RAZORPAY_KEY_ID=""
# RAZORPAY_KEY_SECRET=""
# RAZORPAY_WEBHOOK_SECRET=""


# --- WhatsApp Business Platform (Cloud API) ---------------------------------
# When token + phone-number-id are set, order/inquiry notifications are also
# sent via WhatsApp. Without them, notifications are recorded in-app only.
# Note: business-initiated messages require approved templates (opt-in rules).
# WHATSAPP_TOKEN=""
# WHATSAPP_PHONE_NUMBER_ID=""
# WHATSAPP_API_BASE="https://graph.facebook.com/v21.0"
# WHATSAPP_COUNTRY_CODE="91"
