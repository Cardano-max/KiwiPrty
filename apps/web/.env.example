# App environment (copy to .env and adjust)
# SQLite for local dev; swap to a Postgres URL for production (schema is portable).
DATABASE_URL="file:./dev.db"

# JWT signing secret for auth tokens (use a long random value in production)
JWT_SECRET="dev-only-change-me-to-a-long-random-secret-string"

# Dev OTP: in development the login OTP is returned in the API response and fixed
# so you can log in without a real SMS provider. Set to "0" to disable the shortcut.
DEV_OTP="123456"
